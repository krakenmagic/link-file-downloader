{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.2.0",
  "default_locale": "en",
  "description": "__MSG_appDesc__",
  "permissions": ["downloads", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
