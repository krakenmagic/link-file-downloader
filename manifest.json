{
  "manifest_version": 3,
  "name": "リンク一括ダウンローダー",
  "version": "1.1.0",
  "description": "選択範囲や指定した要素の中にあるリンクから、PDFなどのファイルをまとめてダウンロードします。",
  "permissions": ["downloads", "scripting", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "リンク一括ダウンローダー"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
